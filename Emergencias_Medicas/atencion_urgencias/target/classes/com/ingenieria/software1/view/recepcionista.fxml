<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.RecepcionistaController" prefWidth="800.0" prefHeight="600.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Panel de Gestión de Urgencias" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
    </HBox>

    <Separator />

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button fx:id="btnNuevaUrgencia" text="Registrar Nueva Urgencia" onAction="#onNuevaUrgenciaClick" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Separator orientation="VERTICAL" />
        <Label text="Filtrar por:" />
        <ComboBox fx:id="cbFiltroEstado" prefWidth="130.0" onAction="#onFiltroEstadoChange" />
        <Separator orientation="VERTICAL" />
        <Label text="Asignar a:" />
        <ComboBox fx:id="cbPersonal" prefWidth="180.0" promptText="Seleccionar Médico/Enf." />
        <Button fx:id="btnDespachar" text="Despachar Urgencia" onAction="#onDespacharClick" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="180.0" />
            <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="130.0" />
            <TableColumn fx:id="colGravedad" text="Nivel (1-5)" prefWidth="80.0" />
            <TableColumn fx:id="colHora" text="Hora Reporte" prefWidth="120.0" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100.0" />
            <TableColumn fx:id="colAsignado" text="Personal Asignado" prefWidth="150.0" />
        </columns>
    </TableView>

    <Label fx:id="lblEstadoSistema" text="Sistema listo. Esperando reportes..." style="-fx-font-style: italic;" />
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.paint.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: #66E3D3;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.MedicoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
       
       <HBox alignment="CENTER_LEFT" spacing="20.0">
          <children>
              <VBox>
                 <children>
                     <Label text="Panel de Atención Médica">
                         <font>
                             <Font name="Century" size="24.0" />
                         </font>
                     </Label>
                     <Label fx:id="lblBienvenida" text="Bienvenido, Dr. [Nombre]" textFill="#284e51" />
                 </children>
              </VBox>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="btnCerrarSesion" onAction="#onLogoutClick" style="-fx-background-color: #720004; -fx-text-fill: white;" text="Cerrar Sesión">
               <effect>
                  <Lighting diffuseConstant="1.28" specularConstant="0.86">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
          </children>
       </HBox>
   
       <Separator />
   
       <HBox alignment="CENTER_LEFT" spacing="10.0">
      <children>
              <Label style="-fx-font-weight: bold;" text="Mis Urgencias Asignadas (EN CURSO)" />
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="btnFinalizar" onAction="#onFinalizarClick" style="-fx-background-color: #2D572C; -fx-text-fill: white; -fx-font-weight: bold;" text="Finalizar Atención" textFill="#fffbfb">
               <effect>
                  <Lighting diffuseConstant="1.3" specularConstant="0.5">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
      </children>
       </HBox>
   
       <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
           <columns>
               <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
               <TableColumn fx:id="colDescripcion" prefWidth="250.0" text="Descripción" />
               <TableColumn fx:id="colUbicacion" prefWidth="150.0" text="Ubicación" />
               <TableColumn fx:id="colGravedad" prefWidth="80.0" text="Gravedad" />
               <TableColumn fx:id="colHora" prefWidth="120.0" text="Hora Reporte" />
           </columns>
       </TableView>
   
       <Label fx:id="lblEstadoSistema" style="-fx-font-style: italic;" text="Seleccione una urgencia para finalizar su atención.">
         <font>
            <Font name="Britannic Bold" size="18.0" />
         </font>
      </Label>
   </children>
   <effect>
      <Lighting diffuseConstant="1.33" specularConstant="0.35" specularExponent="31.65" surfaceScale="2.13">
         <bumpInput>
            <Shadow />
         </bumpInput>
         <light>
            <Light.Distant />
         </light>
      </Lighting>
   </effect>
</VBox>

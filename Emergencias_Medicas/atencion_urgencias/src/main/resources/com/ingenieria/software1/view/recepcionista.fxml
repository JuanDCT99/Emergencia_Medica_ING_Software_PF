<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: #66E3D3;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.RecepcionistaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
       
       <HBox alignment="CENTER_LEFT" spacing="20.0">
          <children>
              <Label text="Panel de Gestión de Urgencias" textFill="#2c3e50">
                  <font>
                      <Font name="Century" size="24.0" />
                  </font>
              </Label>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="btnCerrarSesion" onAction="#onLogoutClick" style="-fx-background-color: #720004; -fx-text-fill: white;" text="Cerrar Sesión">
               <effect>
                  <Lighting diffuseConstant="1.53" specularConstant="0.48" specularExponent="32.15" surfaceScale="1.88">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
          </children>
       </HBox>
   
       <Separator />
   
       <HBox alignment="CENTER_LEFT" spacing="10.0">
      <children>
              <Button fx:id="btnNuevaUrgencia" onAction="#onNuevaUrgenciaClick" style="-fx-background-color: #2D572C; -fx-text-fill: white; -fx-font-weight: bold;" text="Registrar Nueva Urgencia">
               <effect>
                  <Lighting diffuseConstant="1.41" specularConstant="0.68" specularExponent="25.06" surfaceScale="1.88">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
              <Separator orientation="VERTICAL" />
              <Label prefHeight="27.0" prefWidth="140.0" text="Filtrar por:" />
              <ComboBox fx:id="cbFiltroEstado" onAction="#onFiltroEstadoChange" prefWidth="130.0" />
              <Separator orientation="VERTICAL" />
              <Label prefHeight="27.0" prefWidth="144.0" text="Asignar a:" />
              <ComboBox fx:id="cbPersonal" prefWidth="180.0" promptText="Seleccionar Médico/Enf." />
              <Button fx:id="btnDespachar" onAction="#onDespacharClick" style="-fx-background-color: #0E1F53; -fx-text-fill: white;" text="Despachar Urgencia">
               <effect>
                  <Lighting diffuseConstant="1.68" specularConstant="0.6" specularExponent="31.65">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
      </children>
       </HBox>
   
       <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
           <columns>
               <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
               <TableColumn fx:id="colDescripcion" prefWidth="180.0" text="Descripción" />
               <TableColumn fx:id="colUbicacion" prefWidth="130.0" text="Ubicación" />
               <TableColumn fx:id="colGravedad" prefWidth="80.0" text="Nivel (1-5)" />
               <TableColumn fx:id="colHora" prefWidth="120.0" text="Hora Reporte" />
               <TableColumn fx:id="colEstado" prefWidth="100.0" text="Estado" />
               <TableColumn fx:id="colAsignado" prefWidth="150.0" text="Personal Asignado" />
           </columns>
       </TableView>
   
       <Label fx:id="lblEstadoSistema" style="-fx-font-style: italic;" text="Sistema listo. Esperando reportes...">
         <font>
            <Font name="Century" size="18.0" />
         </font>
      </Label>
   </children>
   <effect>
      <Lighting diffuseConstant="1.51" specularConstant="0.27" specularExponent="33.67" surfaceScale="2.01">
         <bumpInput>
            <Shadow />
         </bumpInput>
         <light>
            <Light.Distant />
         </light>
      </Lighting>
   </effect>
</VBox>

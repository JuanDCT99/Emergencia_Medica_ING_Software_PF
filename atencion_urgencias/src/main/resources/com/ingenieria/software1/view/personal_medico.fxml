<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.PersonalMedicoController" prefWidth="850.0" prefHeight="650.0" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="panel-header">
        <VBox>
            <Label text="Panel de Personal Médico" styleClass="label-title">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Label fx:id="lblBienvenido" styleClass="label-subtitle" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#onCerrarSesionClick" styleClass="btn-danger" />
    </HBox>

    <Separator />

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="toolbar">
        <Label text="Filtrar por Personal:" styleClass="label-section" />
        <ComboBox fx:id="cbPersonal" prefWidth="200.0" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnFinalizar" text="Finalizar Atención" onAction="#onFinalizarClick" styleClass="btn-success" />
    </HBox>

    <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="200.0" />
            <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="120.0" />
            <TableColumn fx:id="colGravedad" text="Gravedad" prefWidth="80.0" />
            <TableColumn fx:id="colHora" text="Hora Reporte" prefWidth="120.0" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100.0" />
        </columns>
    </TableView>

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="toolbar">
        <Label text="Tareas asignadas:" styleClass="label-section" />
        <Label fx:id="lblTareas" text="Cargando tareas..." styleClass="label-info" />
    </HBox>

    <Label fx:id="lblEstadoSistema" text="Seleccione una urgencia para gestionar." styleClass="label-status" />
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.AdminDashboardController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" styleClass="login-card" layoutX="100.0" layoutY="50.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="50.0">
            <children>
                <Label text="Panel de Administración" styleClass="label-title">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label fx:id="lblBienvenido" styleClass="label-subtitle" />
                <Label text="Desde aquí puedes gestionar los usuarios y ambulancias." styleClass="label-subtitle" />
                
                <Button text="Gestionar Usuarios" onAction="#onGestionarUsuariosClick" prefHeight="35.0" prefWidth="200.0" styleClass="btn-primary" />
                
                <Button text="Gestionar Ambulancias" onAction="#onGestionarAmbulanciasClick" prefHeight="35.0" prefWidth="200.0" styleClass="btn-accent" />
                
                <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#onCerrarSesionClick" prefHeight="30.0" prefWidth="150.0" styleClass="btn-danger" />
            </children>
        </VBox>
    </children>
</AnchorPane>

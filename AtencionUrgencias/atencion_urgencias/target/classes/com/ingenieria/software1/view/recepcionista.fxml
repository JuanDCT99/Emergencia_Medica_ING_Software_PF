<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.RecepcionistaController" prefWidth="900.0" prefHeight="700.0" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="panel-header">
        <Label text="Panel de Gestión de Urgencias" textFill="#2c3e50" styleClass="label-title">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#onLogoutClick" styleClass="btn-danger" />
    </HBox>

    <Separator />

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="toolbar">
        <Button fx:id="btnNuevaUrgencia" text="Registrar Nueva Urgencia" onAction="#onNuevaUrgenciaClick" styleClass="btn-accent" />
        <Separator orientation="VERTICAL" />
        <Label text="Filtrar por:" styleClass="label-section" />
        <ComboBox fx:id="cbFiltroEstado" prefWidth="130.0" onAction="#onFiltroEstadoChange" />
        <Separator orientation="VERTICAL" />
        <Label text="Asignar a:" styleClass="label-section" />
        <ComboBox fx:id="cbPersonal" prefWidth="180.0" promptText="Seleccionar Médico/Enf." />
        <Button fx:id="btnDespachar" text="Despachar Urgencia" onAction="#onDespacharClick" styleClass="btn-primary" />
        <Separator orientation="VERTICAL" />
        <Button fx:id="btnVerFinalizadas" text="Ver Finalizadas" onAction="#onVerFinalizadasClick" styleClass="btn-secondary" />
    </HBox>

    <Label fx:id="lblTituloTabla" text="Urgencias Activas" styleClass="label-section" />
    
    <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="180.0" />
            <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="130.0" />
            <TableColumn fx:id="colGravedad" text="Nivel (1-5)" prefWidth="80.0" />
            <TableColumn fx:id="colHora" text="Hora Reporte" prefWidth="120.0" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100.0" />
            <TableColumn fx:id="colAsignado" text="Personal Asignado" prefWidth="150.0" />
        </columns>
    </TableView>

    <TableView fx:id="tblFinalizadas" VBox.vgrow="ALWAYS" visible="false" managed="false">
        <columns>
            <TableColumn fx:id="colFinId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colFinDescripcion" text="Descripción" prefWidth="180.0" />
            <TableColumn fx:id="colFinUbicacion" text="Ubicación" prefWidth="130.0" />
            <TableColumn fx:id="colFinGravedad" text="Nivel (1-5)" prefWidth="80.0" />
            <TableColumn fx:id="colFinHora" text="Hora Reporte" prefWidth="120.0" />
            <TableColumn fx:id="colFinEstado" text="Estado" prefWidth="100.0" />
            <TableColumn fx:id="colFinAsignado" text="Personal Asignado" prefWidth="150.0" />
        </columns>
    </TableView>

    <Label fx:id="lblEstadoSistema" text="Sistema listo. Esperando reportes..." styleClass="label-status" />
</VBox>

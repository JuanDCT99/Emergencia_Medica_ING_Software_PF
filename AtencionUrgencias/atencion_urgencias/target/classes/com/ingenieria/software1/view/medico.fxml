<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.MedicoController" prefWidth="800.0" prefHeight="600.0" styleClass="root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="panel-header">
        <VBox>
            <Label text="Panel de Atención Médica" styleClass="label-title">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Label fx:id="lblBienvenido" styleClass="label-subtitle" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnCerrarSesion" text="Cerrar Sesión" onAction="#onLogoutClick" styleClass="btn-danger" />
    </HBox>

    <Separator />

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="toolbar">
        <Label text="Filtrar por Médico:" styleClass="label-section" />
        <ComboBox fx:id="cbMedicos" prefWidth="200.0" />
        <Button fx:id="btnTomarUrgencia" text="Tomar Urgencia" onAction="#onTomarClick" styleClass="btn-accent" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnFinalizar" text="Finalizar Atención" onAction="#onFinalizarClick" styleClass="btn-success" />
    </HBox>

    <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="250.0" />
            <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="150.0" />
            <TableColumn fx:id="colGravedad" text="Gravedad" prefWidth="80.0" />
            <TableColumn fx:id="colHora" text="Hora Reporte" prefWidth="120.0" />
            <TableColumn fx:id="colAsignado" text="Asignado a" prefWidth="150.0" />
        </columns>
    </TableView>

    <Label fx:id="lblEstadoSistema" text="Seleccione una urgencia para tomar o finalizar." styleClass="label-status" />
</VBox>

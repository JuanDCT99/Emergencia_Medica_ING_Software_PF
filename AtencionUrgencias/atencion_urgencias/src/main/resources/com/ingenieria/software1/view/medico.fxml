<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: #66E3D3;" styleClass="root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.MedicoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
       
       <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="panel-header">
          <children>
              <VBox>
                 <children>
                     <Label styleClass="label-title" text="Panel de Atención Médica">
                         <font>
                             <Font name="System Bold" size="24.0" />
                         </font>
                     </Label>
                     <Label fx:id="lblBienvenido" styleClass="label-subtitle" />
                 </children>
              </VBox>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="btnCerrarSesion" onAction="#onLogoutClick" style="-fx-background-color: #720004;" styleClass="btn-danger" text="Cerrar Sesión" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <effect>
                  <Lighting diffuseConstant="1.53" specularConstant="0.73" specularExponent="25.57" surfaceScale="3.15">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
          </children>
       </HBox>
   
       <Separator />
   
       <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar">
      <children>
              <Label styleClass="label-section" text="Filtrar por Médico:" />
              <ComboBox fx:id="cbMedicos" prefWidth="200.0" />
              <Button fx:id="btnTomarUrgencia" onAction="#onTomarClick" style="-fx-background-color: #2D572C;" styleClass="btn-accent" text="Tomar Urgencia" textFill="WHITE">
               <effect>
                  <Lighting diffuseConstant="1.35" specularConstant="0.71" specularExponent="27.59" surfaceScale="3.27">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="btnFinalizar" onAction="#onFinalizarClick" style="-fx-background-color: #0E1F53;" styleClass="btn-success" text="Finalizar Atención" textFill="WHITE">
               <effect>
                  <Lighting diffuseConstant="1.73" specularConstant="0.68" specularExponent="27.59" surfaceScale="3.15">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
      </children>
       </HBox>
   
       <TableView fx:id="tblUrgencias" VBox.vgrow="ALWAYS">
           <columns>
               <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
               <TableColumn fx:id="colDescripcion" prefWidth="250.0" text="Descripción" />
               <TableColumn fx:id="colUbicacion" prefWidth="150.0" text="Ubicación" />
               <TableColumn fx:id="colGravedad" prefWidth="80.0" text="Gravedad" />
               <TableColumn fx:id="colHora" prefWidth="120.0" text="Hora Reporte" />
               <TableColumn fx:id="colAsignado" prefWidth="150.0" text="Asignado a" />
           </columns>
       </TableView>
   
       <Label fx:id="lblEstadoSistema" styleClass="label-status" text="Seleccione una urgencia para tomar o finalizar." />
   </children>
   <effect>
      <Lighting diffuseConstant="1.43" specularConstant="0.71" specularExponent="27.59" surfaceScale="3.53">
         <bumpInput>
            <Shadow />
         </bumpInput>
         <light>
            <Light.Distant />
         </light>
      </Lighting>
   </effect>
</VBox>

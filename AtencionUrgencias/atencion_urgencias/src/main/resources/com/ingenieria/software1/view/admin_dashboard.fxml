<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #66E3D3;" styleClass="root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.AdminDashboardController">
    <children>
        <VBox alignment="CENTER" layoutX="100.0" layoutY="70.0" spacing="20.0" styleClass="login-card" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="70.0">
            <children>
                <Label styleClass="label-title" text="Panel de Administración" translateY="50.0">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label fx:id="lblBienvenido" styleClass="label-subtitle" />
                <Label styleClass="label-subtitle" text="Desde aquí puedes gestionar los usuarios del sistema." />
                
                <Button onAction="#onGestionarUsuariosClick" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #2D572C;" styleClass="btn-primary" text="Gestionar Usuarios" textFill="WHITE">
               <effect>
                  <Lighting diffuseConstant="1.73" specularConstant="0.91" specularExponent="28.61" surfaceScale="2.51">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect></Button>
                
                <Button fx:id="btnCerrarSesion" onAction="#onCerrarSesionClick" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #720004;" styleClass="btn-danger" text="Cerrar Sesión" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <effect>
                  <Lighting diffuseConstant="1.58" specularConstant="0.63" specularExponent="26.58" surfaceScale="2.64">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect></Button>
            </children>
        </VBox>
      <Line endX="-100.0" endY="340.0" layoutX="115.0" layoutY="31.0" startX="-100.0" />
      <Line endX="-100.0" endY="340.0" layoutX="686.0" layoutY="32.0" startX="-100.0" />
      <ImageView fitHeight="101.0" fitWidth="111.0" layoutX="250.0" layoutY="32.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@admin.png" />
         </image>
      </ImageView>
    </children>
   <effect>
      <Lighting diffuseConstant="1.53" specularConstant="0.35" specularExponent="31.14" surfaceScale="3.65">
         <bumpInput>
            <Shadow />
         </bumpInput>
         <light>
            <Light.Distant />
         </light>
      </Lighting>
   </effect>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="500.0" spacing="10.0" style="-fx-background-color: #66E3D3;" styleClass="card" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.RegistroUrgenciaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
   
       <Label styleClass="label-title" text="Nuevo Reporte de Urgencia">
           <font>
               <Font name="System Bold" size="20.0" />
           </font>
       </Label>
   
       <Separator />
   
       <GridPane hgap="10.0" vgap="10.0">
           <columnConstraints>
               <ColumnConstraints prefWidth="120.0" />
               <ColumnConstraints hgrow="ALWAYS" />
           </columnConstraints>
      <children>
              
              <Label styleClass="label-section" text="Documento ID:" GridPane.rowIndex="0" />
              <TextField fx:id="txtDocumento" promptText="Cédula del paciente" GridPane.columnIndex="1" GridPane.rowIndex="0" />
      
              <Label styleClass="label-section" text="Nombre Completo:" GridPane.rowIndex="1" />
              <TextField fx:id="txtNombre" promptText="Nombre del paciente" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      
              <Label styleClass="label-section" text="Edad:" GridPane.rowIndex="2" />
              <TextField fx:id="txtEdad" promptText="Edad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      
              <Label styleClass="label-section" text="Género:" GridPane.rowIndex="3" />
              <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                 <children>
                     <RadioButton fx:id="rbMasculino" selected="true" text="Masculino" />
                     <RadioButton fx:id="rbFemenino" text="Femenino" />
                 </children>
              </HBox>
      
              <Label styleClass="label-section" text="Sintomatología:" GridPane.rowIndex="4" />
              <TextArea fx:id="txtSintomas" prefHeight="80.0" promptText="Descripción detallada del reporte inicial" GridPane.columnIndex="1" GridPane.rowIndex="4" />
      
              <Label styleClass="label-section" text="Ubicación:" GridPane.rowIndex="5" />
              <TextField fx:id="txtUbicacion" promptText="Dirección o punto del reporte" GridPane.columnIndex="1" GridPane.rowIndex="5" />
      
              <Label styleClass="label-section" text="Nivel de triage:" GridPane.rowIndex="6" />
              <ComboBox fx:id="cbTriage" maxWidth="Infinity" promptText="Seleccionar prioridad" GridPane.columnIndex="1" GridPane.rowIndex="6" />
      
              <Label styleClass="label-section" text="Signos Vitales:" GridPane.rowIndex="7" />
              <TextField fx:id="txtSignos" promptText="Presión, Ritmo Cardiaco, Saturación..." GridPane.columnIndex="1" GridPane.rowIndex="7" />
      </children>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
       </GridPane>
   
       <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <children>
              <Button onAction="#onCancelarClick" style="-fx-background-color: #720004;" styleClass="btn-secondary" text="Cancelar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <effect>
                  <Lighting diffuseConstant="1.46" specularConstant="0.6" specularExponent="24.56" surfaceScale="3.65">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
              <Button onAction="#onRegistrarClick" style="-fx-background-color: #2D572C;" styleClass="btn-success" text="Registrar Urgencia" textFill="WHITE">
               <effect>
                  <Lighting diffuseConstant="1.66" specularConstant="0.78" specularExponent="24.05" surfaceScale="3.91">
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
            </Button>
      </children>
       </HBox>
   </children>
   <effect>
      <Lighting diffuseConstant="1.58" specularConstant="0.65" specularExponent="28.1" surfaceScale="2.51">
         <bumpInput>
            <Shadow />
         </bumpInput>
         <light>
            <Light.Distant />
         </light>
      </Lighting>
   </effect>
</VBox>

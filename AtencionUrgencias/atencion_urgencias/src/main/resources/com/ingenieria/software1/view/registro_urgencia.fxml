<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ingenieria.software1.controller.RegistroUrgenciaController" prefWidth="500.0" styleClass="card">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Nuevo Reporte de Urgencia" styleClass="label-title">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <Separator />

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints prefWidth="120.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Documento ID:" GridPane.rowIndex="0" styleClass="label-section" />
        <TextField fx:id="txtDocumento" promptText="Cédula del paciente" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Nombre Completo:" GridPane.rowIndex="1" styleClass="label-section" />
        <TextField fx:id="txtNombre" promptText="Nombre del paciente" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Edad:" GridPane.rowIndex="2" styleClass="label-section" />
        <TextField fx:id="txtEdad" promptText="Edad" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Género:" GridPane.rowIndex="3" styleClass="label-section" />
        <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <RadioButton fx:id="rbMasculino" text="Masculino" selected="true" />
            <RadioButton fx:id="rbFemenino" text="Femenino" />
        </HBox>

        <Label text="Sintomatología:" GridPane.rowIndex="4" styleClass="label-section" />
        <TextArea fx:id="txtSintomas" prefHeight="80.0" promptText="Descripción detallada del reporte inicial" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <Label text="Ubicación:" GridPane.rowIndex="5" styleClass="label-section" />
        <TextField fx:id="txtUbicacion" promptText="Dirección o punto del reporte" GridPane.columnIndex="1" GridPane.rowIndex="5" />

        <Label text="Nivel de triage:" GridPane.rowIndex="6" styleClass="label-section" />
        <ComboBox fx:id="cbTriage" promptText="Seleccionar prioridad" GridPane.columnIndex="1" GridPane.rowIndex="6" maxWidth="Infinity" />

        <Label text="Signos Vitales:" GridPane.rowIndex="7" styleClass="label-section" />
        <TextField fx:id="txtSignos" promptText="Presión, Ritmo Cardiaco, Saturación..." GridPane.columnIndex="1" GridPane.rowIndex="7" />
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Cancelar" onAction="#onCancelarClick" styleClass="btn-secondary" />
        <Button text="Registrar Urgencia" onAction="#onRegistrarClick" styleClass="btn-success" />
    </HBox>
</VBox>
